{
  "openapi": "3.0.0",
  "info": {
    "title": "Inventory Service API",
    "version": "1.0.0",
    "description": "API Gateway Test - Inventory Service Mock API"
  },
  "servers": [
    {
      "url": "http://localhost:3005",
      "description": "Inventory Service Port"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/inventory/{productId}": {
      "get": {
        "summary": "Get inventory stock level",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stock count information"
          }
        }
      }
    },
    "/inventory/reduce": {
      "post": {
        "summary": "Reduce inventory stock",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "productId": { "type": "string" },
                  "quantity": { "type": "integer" }
                },
                "required": ["productId", "quantity"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stock reduction success"
          },
          "400": {
            "description": "Invalid parameters"
          }
        }
      }
    }
  }
}
