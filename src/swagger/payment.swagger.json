{
  "openapi": "3.0.0",
  "info": {
    "title": "Payment Service API",
    "version": "1.0.0",
    "description": "API Gateway Test - Payment Service Mock API"
  },
  "servers": [
    {
      "url": "http://localhost:3004",
      "description": "Payment Service Port"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/payments/pay": {
      "post": {
        "summary": "Process payment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "orderId": { "type": "string" },
                  "amount": { "type": "number" },
                  "paymentMethod": { "type": "string" }
                },
                "required": ["orderId", "amount", "paymentMethod"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment success"
          },
          "400": {
            "description": "Missing parameters"
          }
        }
      }
    },
    "/payments/cancel": {
      "post": {
        "summary": "Cancel payment (refund)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transactionId": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "required": ["transactionId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cancellation success"
          },
          "400": {
            "description": "Missing parameters"
          }
        }
      }
    }
  }
}
