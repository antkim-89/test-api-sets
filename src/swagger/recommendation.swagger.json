{
  "openapi": "3.0.0",
  "info": {
    "title": "Recommendation Service API",
    "version": "1.0.0",
    "description": "API Gateway Test - Recommendation Service Mock API"
  },
  "servers": [
    {
      "url": "http://localhost:3010",
      "description": "Recommendation Service Port"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/recommendations/user/{userId}": {
      "get": {
        "summary": "Get user personalized recommendation products",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Personalized recommendation list"
          }
        }
      }
    },
    "/recommendations/trending": {
      "get": {
        "summary": "Get trending products",
        "responses": {
          "200": {
            "description": "Trending recommendations"
          }
        }
      }
    }
  }
}
