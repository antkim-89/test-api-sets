{
  "openapi": "3.0.0",
  "info": {
    "title": "Delivery Service API",
    "version": "1.0.0",
    "description": "API Gateway Test - Delivery Service Mock API"
  },
  "servers": [
    {
      "url": "http://localhost:3007",
      "description": "Delivery Service Port"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/delivery/{orderId}": {
      "get": {
        "summary": "Get delivery status",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery tracking status"
          }
        }
      }
    },
    "/delivery/track": {
      "post": {
        "summary": "Register shipping tracker",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "orderId": { "type": "string" },
                  "address": { "type": "string" }
                },
                "required": ["orderId", "address"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tracker registered"
          },
          "400": {
            "description": "Invalid parameters"
          }
        }
      }
    }
  }
}
