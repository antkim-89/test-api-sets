{
  "openapi": "3.0.0",
  "info": {
    "title": "Notification Service API",
    "version": "1.0.0",
    "description": "API Gateway Test - Notification Service Mock API"
  },
  "servers": [
    {
      "url": "http://localhost:3008",
      "description": "Notification Service Port"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/notifications/send": {
      "post": {
        "summary": "Send notification",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": { "type": "string" },
                  "type": { "type": "string" },
                  "message": { "type": "string" }
                },
                "required": ["userId", "type", "message"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification dispatch confirmation"
          },
          "400": {
            "description": "Missing parameters"
          }
        }
      }
    },
    "/notifications/history": {
      "get": {
        "summary": "Get notification history",
        "responses": {
          "200": {
            "description": "List of sent notifications"
          }
        }
      }
    }
  }
}
