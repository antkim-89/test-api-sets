{
  "openapi": "3.0.0",
  "info": {
    "title": "Order Service API",
    "version": "1.0.0",
    "description": "API Gateway Test - Order Service Mock API"
  },
  "servers": [
    {
      "url": "http://localhost:3003",
      "description": "Order Service Port"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Create order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": { "type": "string" },
                  "items": { "type": "array", "items": { "type": "object" } },
                  "totalAmount": { "type": "number" }
                },
                "required": ["userId", "items", "totalAmount"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created successfully"
          },
          "400": {
            "description": "Missing parameters"
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "summary": "Get order details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order detail information"
          }
        }
      }
    }
  }
}
